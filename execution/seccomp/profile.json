{
  "defaultAction": "SCMP_ACT_ERRNO",
  "architectures": ["SCMP_ARCH_X86_64", "SCMP_ARCH_X86", "SCMP_ARCH_X32", "SCMP_ARCH_AARCH64"],
  "syscalls": [
    {
      "comment": "Allow filesystem operations",
      "names": [
        "read", "write", "open", "openat", "openat2", "close",
        "stat", "fstat", "lstat", "newfstatat", "statx", "statfs", "fstatfs",
        "lseek", "pread64", "pwrite64", "readv", "writev", "preadv", "pwritev",
        "access", "faccessat", "faccessat2",
        "getcwd", "chdir", "fchdir",
        "rename", "renameat", "renameat2",
        "mkdir", "mkdirat", "rmdir",
        "creat", "link", "linkat", "unlink", "unlinkat",
        "symlink", "symlinkat", "readlink", "readlinkat",
        "chmod", "fchmod", "fchmodat",
        "chown", "fchown", "fchownat", "lchown",
        "umask", "truncate", "ftruncate",
        "getdents", "getdents64",
        "fcntl", "flock", "fsync", "fdatasync",
        "dup", "dup2", "dup3", "pipe", "pipe2",
        "sendfile", "copy_file_range", "splice", "tee", "vmsplice",
        "fallocate", "fadvise64"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Allow process and memory management",
      "names": [
        "mmap", "mprotect", "munmap", "brk", "mremap", "msync",
        "mincore", "madvise", "mlock", "munlock", "mlockall", "munlockall",
        "mlock2", "membarrier", "mbind", "set_mempolicy", "get_mempolicy",
        "move_pages", "migrate_pages",
        "clone", "clone3", "fork", "vfork", "execve", "execveat",
        "exit", "exit_group", "wait4", "waitid",
        "getpid", "getppid", "getpgrp", "getpgid", "getsid",
        "setpgid", "setsid",
        "getuid", "getgid", "geteuid", "getegid",
        "getresuid", "getresgid", "getgroups",
        "arch_prctl", "prctl",
        "set_tid_address", "gettid", "tkill", "tgkill", "kill",
        "restart_syscall"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Allow signals and timers",
      "names": [
        "rt_sigaction", "rt_sigprocmask", "rt_sigreturn",
        "rt_sigpending", "rt_sigtimedwait", "rt_sigqueueinfo",
        "rt_sigsuspend", "rt_tgsigqueueinfo", "sigaltstack",
        "alarm", "setitimer", "getitimer",
        "timer_create", "timer_settime", "timer_gettime",
        "timer_getoverrun", "timer_delete",
        "timerfd_create", "timerfd_settime", "timerfd_gettime",
        "nanosleep", "clock_nanosleep",
        "clock_gettime", "clock_getres", "gettimeofday", "time", "times",
        "getrusage", "sysinfo"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Allow I/O multiplexing and events",
      "names": [
        "poll", "ppoll", "select", "pselect6",
        "epoll_create", "epoll_create1", "epoll_ctl", "epoll_wait", "epoll_pwait",
        "inotify_init", "inotify_init1", "inotify_add_watch", "inotify_rm_watch",
        "eventfd", "eventfd2", "signalfd", "signalfd4",
        "io_setup", "io_destroy", "io_getevents", "io_submit", "io_cancel",
        "io_pgetevents"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Allow IPC primitives needed by Python/Ansible",
      "names": [
        "shmget", "shmat", "shmctl", "shmdt",
        "semget", "semop", "semctl", "semtimedop",
        "msgget", "msgsnd", "msgrcv", "msgctl",
        "mq_open", "mq_unlink", "mq_timedsend",
        "mq_timedreceive", "mq_notify", "mq_getsetattr",
        "socketpair", "recvmsg", "sendmsg",
        "futex", "set_robust_list", "get_robust_list",
        "sched_yield", "sched_setaffinity", "sched_getaffinity",
        "sched_getparam", "sched_setparam",
        "sched_getscheduler", "sched_setscheduler",
        "sched_get_priority_max", "sched_get_priority_min",
        "sched_rr_get_interval", "sched_setattr", "sched_getattr",
        "capget"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Allow misc syscalls required by Python runtime",
      "names": [
        "utime", "utimes", "utimensat", "futimesat",
        "mknod", "mknodat", "ioctl",
        "getrandom", "memfd_create",
        "ioprio_set", "ioprio_get",
        "set_thread_area", "get_thread_area",
        "remap_file_pages", "lookup_dcookie",
        "personality", "sysfs", "ustat",
        "prlimit64", "getrlimit", "setrlimit",
        "getpriority", "setpriority",
        "pause", "sched_yield",
        "uname", "vhangup", "modify_ldt",
        "quotactl", "sync", "syncfs"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "BLOCK: privilege escalation",
      "names": [
        "setuid", "setgid", "setreuid", "setregid",
        "setresuid", "setresgid", "setfsuid", "setfsgid",
        "setgroups", "capset"
      ],
      "action": "SCMP_ACT_ERRNO"
    },
    {
      "comment": "BLOCK: kernel/namespace/host manipulation",
      "names": [
        "mount", "umount2", "pivot_root", "chroot",
        "sethostname", "setdomainname",
        "reboot", "swapon", "swapoff",
        "settimeofday", "clock_settime", "clock_adjtime",
        "iopl", "ioperm",
        "create_module", "init_module", "delete_module", "finit_module",
        "kexec_load", "kexec_file_load",
        "unshare", "setns",
        "bpf", "perf_event_open",
        "fanotify_init", "fanotify_mark",
        "add_key", "request_key", "keyctl",
        "process_vm_readv", "process_vm_writev",
        "kcmp", "seccomp",
        "open_by_handle_at", "name_to_handle_at",
        "userfaultfd",
        "ptrace", "acct"
      ],
      "action": "SCMP_ACT_ERRNO"
    }
  ]
}
