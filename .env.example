# Environment — copy to .env and fill in all values

APP_ENV=development

# PostgreSQL
POSTGRES_DB=cis
POSTGRES_USER=cis
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://cis:CHANGE_ME_STRONG_PASSWORD@postgres:5432/cis

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# JWT — generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHAR_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=cis-scripts
MINIO_SECURE=false

# Docker sandbox
DOCKER_SOCKET=/var/run/docker.sock
EXECUTION_IMAGE=cis-runner:latest
TASK_TIMEOUT=300
MAX_MEMORY=256m
MAX_CPUS=0.5
# Path where the seccomp profile is mounted inside the worker container
SECCOMP_PROFILE_PATH=/etc/seccomp/profile.json
# Name of the AppArmor profile loaded on the Docker host (leave empty to disable)
APPARMOR_PROFILE=

# CORS (JSON list of allowed origins)
ALLOWED_ORIGINS=["https://yourdomain.com"]
