# Environment configuration for CIS backend
APP_ENV=development

# PostgreSQL
POSTGRES_DB=cis
POSTGRES_USER=cis
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://cis:change_me_strong_password@postgres:5432/cis

# Redis
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_REPLACE_WITH_64_CHAR_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_password
MINIO_BUCKET=cis-scripts
MINIO_SECURE=false

# Docker sandbox
DOCKER_SOCKET=/var/run/docker.sock
EXECUTION_IMAGE=cis-runner:latest
TASK_TIMEOUT=300
MAX_MEMORY=256m
MAX_CPUS=0.5

# CORS (comma-separated origins)
ALLOWED_ORIGINS=["https://yourdomain.com"]
